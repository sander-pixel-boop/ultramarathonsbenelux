const MAX_MEMO_SIZE = 5000;
const parseStandardDateMemo = new globalThis.Map();

export function parseStandardDate(dateStr) {
    if (!dateStr) return null;
    const str = String(dateStr).trim();

    if (parseStandardDateMemo.has(str)) {
        return parseStandardDateMemo.get(str);
    }

    let result = null;

    // Check for DD Month YYYY
    const monthNamesEn = ['january', 'february', 'march', 'april', 'may', 'june', 'july', 'august', 'september', 'october', 'november', 'december'];
    const monthNamesShort = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];

    // YYYY-MM-DD or YYYY.MM.DD or YYYY/MM/DD
    let match = str.match(/^(\d{4})[-./](\d{1,2})[-./](\d{1,2})$/);
    if (match) {
        const month = parseInt(match[2], 10);
        if (month >= 1 && month <= 12) {
            result = { year: parseInt(match[1], 10), month, day: parseInt(match[3], 10) };
        }
    }

    // DD-MM-YYYY or DD.MM.YYYY or DD/MM/YYYY or DD.MM.YY
    if (!result) {
        match = str.match(/^(\d{1,2})[-./](\d{1,2})[-./](\d{2,4})$/);
        if (match) {
            const month = parseInt(match[2], 10);
            if (month >= 1 && month <= 12) {
                let year = parseInt(match[3], 10);
                if (year < 100) year += 2000;
                result = { day: parseInt(match[1], 10), month, year };
            }
        }
    }

    // DD Month YYYY
    if (!result) {
        match = str.match(/^(\d{1,2})\s+([A-Za-z]+)\s+(\d{4})$/);
        if (match) {
            const mStr = match[2].toLowerCase();
            let month = monthNamesEn.indexOf(mStr) + 1;
            if (month === 0) month = monthNamesShort.findIndex(m => mStr.startsWith(m)) + 1;
            if (month !== 0) {
                result = { day: parseInt(match[1], 10), month, year: parseInt(match[3], 10) };
            }
        }
    }

    if (parseStandardDateMemo.size >= MAX_MEMO_SIZE) {
        parseStandardDateMemo.clear();
    }
    parseStandardDateMemo.set(str, result);

    return result;
}
